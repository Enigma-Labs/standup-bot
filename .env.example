# Linear
# Generate at: https://linear.app/enigma/settings/api
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Linear team ID for the Engineering team
# Find by running: curl -X POST https://api.linear.app/graphql \
#   -H "Authorization: YOUR_KEY" -H "Content-Type: application/json" \
#   -d '{"query":"{ teams { nodes { id name } } }"}'
LINEAR_TEAM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slack — Bot Token (for posting to #product-drafts)
# Create app at: https://api.slack.com/apps
# Required bot scopes: chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx

# Slack — your Slack user ID (for DM drafts)
# Find by clicking your name in Slack → View profile → the ID starts with U
SLACK_DRAFT_USER_ID=U0XXXXXXXXX

# Slack channel ID for #product
# Find by right-clicking the channel in Slack → View channel details → scroll to bottom
SLACK_PRODUCT_CHANNEL_ID=C0XXXXXXXXX

# Anthropic
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron secret — set this to any random string, add to Vercel env vars
# Used to secure the cron endpoints so only Vercel can trigger them
CRON_SECRET=your-random-secret-here
